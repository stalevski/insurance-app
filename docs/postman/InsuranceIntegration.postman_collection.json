{
  "info": {
    "name": "InsuranceIntegration.Api",
    "description": "Curated Postman collection for the InsuranceIntegration.Api service. Mirrors the scenarios in docs/API_EXAMPLES.md. Set `baseUrl` in the matching environment file (defaults to http://localhost:5000). Each request injects a fresh `X-Correlation-Id` via the collection-level pre-request script so log scopes are unique per send.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Generate a fresh correlation id per request so logs can be traced",
          "pm.collectionVariables.set('correlationId', (pm.variables.replaceIn('{{$guid}}') || ''));",
          "// Generate a fresh envelope id per send (used by ingest requests)",
          "pm.collectionVariables.set('envelopeId', 'evt-' + Date.now());",
          "// Stable UTC timestamp",
          "pm.collectionVariables.set('nowUtc', new Date().toISOString());"
        ]
      }
    }
  ],
