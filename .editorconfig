# EditorConfig: https://editorconfig.org
# Top-most config file in the repo
root = true

###############################
# Defaults for all files
###############################
[*]
indent_style = space
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

###############################
# C# source files
###############################
[*.cs]
indent_size = 4

# Use file-scoped namespaces (existing convention in this repo)
csharp_style_namespace_declarations = file_scoped:warning

# Using directives go outside the namespace declaration
csharp_using_directive_placement = outside_namespace:warning

# Prefer 'var' (existing convention)
csharp_style_var_for_built_in_types = true:silent
csharp_style_var_when_type_is_apparent = true:silent
csharp_style_var_elsewhere = true:silent

# Allman-style braces (open brace on a new line) - existing convention
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

# Indentation
csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents = true
csharp_indent_case_contents_when_block = true
csharp_indent_switch_labels = true
csharp_indent_labels = flush_left

# Spacing
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_between_method_call_empty_parameter_list_parentheses = false
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_parentheses = false
csharp_space_after_cast = false

# Wrapping
csharp_preserve_single_line_blocks = true
csharp_preserve_single_line_statements = true

###############################
# Analyzer rule tuning (C# only)
###############################
[*.cs]
# CA1848: prefers LoggerMessage delegates over direct LogInformation/LogError calls
# for perf reasons. Negligible benefit for this codebase's logging cadence
# (background poller every 2s, low-volume request logs); demote to suggestion
# so it surfaces in IDE but does not fail CI.
dotnet_diagnostic.CA1848.severity = suggestion

###############################
# Test files - relax naming conventions
###############################
[tests/**/*.cs]
# CA1707: member names should not contain underscores. Test methods follow the
# Method_ExpectedBehavior_WhenCondition convention (e.g. Process_AutoClears_WhenEligible)
# which deliberately uses underscores for readability in test runner output.
dotnet_diagnostic.CA1707.severity = none

###############################
# Project / build / solution files
###############################
[*.{csproj,props,targets,sln}]
indent_size = 2

###############################
# Config / data files
###############################
[*.{json,yml,yaml}]
indent_size = 2

###############################
# Markdown
###############################
[*.md]
# Markdown uses trailing spaces for line breaks - do not strip
trim_trailing_whitespace = false
