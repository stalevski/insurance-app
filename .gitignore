# ============================================================
# Build outputs
# ============================================================
bin/
obj/
artifacts/
publish/
Publish/

# ============================================================
# .NET / MSBuild
# *.user covers *.csproj.user, *.DotSettings.user (ReSharper),
# and other IDE per-user files.
# ============================================================
*.user
*.suo
*.cache
*.pdb
*.binlog
*.tlog
*.[Pp]ublish.xml
PublishProfiles/

# ============================================================
# NuGet
# ============================================================
*.nupkg
*.snupkg

# ============================================================
# Tests / coverage
# ============================================================
TestResults/
coverage.cobertura.xml
coverage.opencover.xml
*.coverage

# ============================================================
# Logs (also covers npm-debug.log, yarn-error.log)
# ============================================================
*.log

# ============================================================
# Local databases (SQLite + WAL / SHM / journal sidecars)
# ============================================================
*.db
*.db-journal
*.db-shm
*.db-wal

# ============================================================
# Secrets / local-only configuration
# ============================================================
.env
.env.*
secrets.json
*.pfx
*.cer
*.p12
*.key
appsettings.Local.json
appsettings.*.local.json

# ============================================================
# IDEs
# ============================================================
.vs/
.vscode/*
# Keep shared, repo-level VS Code tasks (Start app / Stop app) under version control.
!.vscode/tasks.json
.idea/
_ReSharper*/

# ============================================================
# OS metadata
# ============================================================
.DS_Store
desktop.ini

# ============================================================
# Editor backup / swap files
# ============================================================
*.swp
*.swo
*~
*.bak
*.orig
*.rej

# ============================================================
# Frontend (reserved for future use)
# ============================================================
node_modules/
.next/
.nuxt/
dist/
build/
